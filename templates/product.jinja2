{% include "header.jinja2" %}

<div class="product-hero">
	<div>
		<h2>{{ item['brand'] }} <span class="dull">{{ item['product'] }}</span></h2>
		<p class="dull small">{{ item['size'] }}ml; {{ item['packaging'] }}; <a class="nav-link small" href="https://github.com/matelab-ch/matelab/blob/main/data/{{ item['filename'] }}" target="_blank">View on GitHub ↗</a></p>
	</div>
</div>

<div class="stats-grid">
	<div class="stat-card">
		<div class="x-small">Caffeine</div>
		<div class="accent">{{ item['caffeine'] }}<span class="dull x-small"> mg/100ml</span></div>
	</div>
	<div class="stat-card">
		<div class="x-small">Total Caffeine</div>
		<div class="accent">{{ item['caffeinetotal'] }}<span class="dull x-small"> mg</span></div>
	</div>
	<div class="stat-card">
		<div class="x-small">Sugar</div>
		<div class="accent">{{ item['sugar'] }}<span class="dull x-small"> g/100ml</span></div>
	</div>
	<div class="stat-card">
		<div class="x-small">Total Sugar</div>
		<div class="accent">{{ item['sugartotal'] }}<span class="dull x-small"> g</span></div>
	</div>
	<div class="stat-card">
		<div class="x-small">Avg Price</div>
		<div class="accent">{{ item['averageprice'] }}<span class="dull x-small"> CHF</span></div>
	</div>
	<div class="stat-card" title="Caffeine/((Sugar+1)*AvrPrice)">
		<div class="x-small">Score</div>
		<div class="accent">{{ item['score'] }}</div>
	</div>
</div>

<h3>Ingredients</h3>
<ul>
	{% for ingredient in item['ingredients'] %}
	<li>{{ ingredient }}</li>
	{% endfor %}
</ul>

<h3>Stores</h3>
{% if item['discontinued'] %}
<p class="dull">This product is no longer available.</p>
{% else %}
<div class="table-container">
	<table id="product-table" class="display compact">
		<thead>
			<tr>
				<th>Store</th>
				<th class="numeric">Price 1 Unit<br><small>(CHF)</small></th>
				<th class="numeric">Price 1 Pack<br><small>(CHF)</small></th>
				<th class="numeric">Units per Pack</th>
				<th>Comment</th>
				<th>Last modified</th>
			</tr>
		</thead>
		<tbody>
			{% for store in item['stores'] %}
			<tr>
				<td><a href="{{ store['url'] }}" target="_blank" rel="noopener noreferrer">{{ store['name'] }} ↗</a></td>
				<td class="numeric">{{ store['price1u'] }}</td>
				<td class="numeric">{{ store['price'] }}</td>
				<td class="numeric">{{ store['amount'] }}</td>
				<td>{{ store['comment'] }}</td>
				<td class="dull">{{ store['date'] }}</td>
			</tr>
			{% endfor %}
		</tbody>
	</table>
</div>
{% endif %}

<script>
$(document).ready(function() {
	$('#product-table').DataTable({
		order: [[0, 'asc']],
		columnDefs: [
			{ targets: [1, 2, 3], className: 'numeric' }
		],
		scrollX: true,
		paging: false,
		bInfo: false,
		searching: false,
	});
});
</script>

{% include "footer.jinja2" %}